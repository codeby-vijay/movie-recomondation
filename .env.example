# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production-abc123

# Database
# DATABASE_URL is set automatically in config.py using an absolute path

# OMDb API
OMDB_API_KEY=your_tmdb_api_key_here
OMDB_BASE_URL=http://www.omdbapi.com/

# ML Configuration
ML_MODEL_PATH=data/models/
ML_DATA_PATH=data/raw/
ML_PROCESSED_PATH=data/processed/

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# Server
HOST=0.0.0.0
PORT=5000
